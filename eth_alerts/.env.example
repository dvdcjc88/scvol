# ── Required ──────────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal or group chat ID. Send any message to your bot, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates — look for "chat": {"id": ...}
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Optional enrichment ───────────────────────────────────────────────────────
# CoinGlass API key (free tier) for enhanced liquidation heatmap data
COINGLASS_API_KEY=

# ── Polling ────────────────────────────────────────────────────────────────────
POLL_INTERVAL=60           # seconds between each data fetch
COOLDOWN_MINUTES=30        # minimum gap between same-type alerts

# ── Alert threshold: how many signals must fire to send an alert ───────────────
MIN_SIGNALS_FOR_ALERT=3    # out of 7 possible signals

# ── Signal 1: DVOL / IV Term Structure ───────────────────────────────────────
DVOL_SPIKE_PCT=10.0           # DVOL must rise ≥ 10% in the past hour
DVOL_BACKWARDATION_PTS=2.0    # front_IV − back_IV ≥ 2 vol pts = backwardation

# ── Signal 2: VRP (Volatility Risk Premium) ──────────────────────────────────
VRP_RATIO_THRESHOLD=80.0      # RV/IV ≥ 80% → VRP compressing (gamma suppression breaking)

# ── Signal 3: Perp Funding + OI ──────────────────────────────────────────────
FUNDING_NEGATIVE=-0.0001      # ≤ −0.01% per 8h = bearish funding (sell-puts trigger)
FUNDING_POSITIVE=0.0002       # ≥ +0.02% per 8h = aggressive long leverage (sell-calls)
OI_RISING_PCT=1.5             # OI must rise ≥ 1.5% vs previous poll

# ── Signal 4: CVD / Spot-Perp Basis ─────────────────────────────────────────
CVD_NEGATIVE_USD=-300000      # CVD ≤ −$300K in last ~1000 trades = aggressive selling
CVD_POSITIVE_USD=300000       # CVD ≥ +$300K = aggressive buying
BASIS_DISCOUNT_USD=5.0        # spot < perp by ≥ $5 = spot leading down
BASIS_PREMIUM_USD=5.0         # perp > spot by ≥ $5 = spot leading up

# ── Signal 5: Liquidation Sweep ──────────────────────────────────────────────
LIQ_WINDOW_MIN=15             # look-back window in minutes
LIQ_THRESHOLD_USD=1000000     # ≥ $1M liquidated in window = sweep

# ── Signal 6: 0DTE / Front-Expiry Skew ──────────────────────────────────────
SKEW_COMPRESSION_PTS=4.0      # put skew must drop ≥ 4 vol pts from recent high
SKEW_HIGH_WINDOW=20           # number of polls to track skew high over

# ── Signal 7: GEX Wall (bonus) ────────────────────────────────────────────────
GEX_PROXIMITY_PCT=1.5         # price within 1.5% of a gamma wall = trigger
